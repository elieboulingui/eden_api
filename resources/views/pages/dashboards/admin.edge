<!-- 🆕 SECTION MARCHANDS ACTIFS ET INACTIFS -->
<section class="home-section" style="padding: 0 30px 40px;">
  <header class="home-section-head" style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 20px; flex-wrap: wrap; gap: 16px;">
    <div>
      <h2 style="font-size: 24px; font-weight: 700;">🛍️ Gestion des marchands</h2>
      <p style="color: #64748b;">{{ totalMerchants ?? '0' }} marchands au total</p>
    </div>
    <div style="display: flex; gap: 12px;">
      <button onclick="filterMerchants('all')" id="filterAllBtn" class="filter-btn" style="background: #3b82f6; color: white; padding: 8px 16px; border: none; border-radius: 10px; cursor: pointer;">Tous ({{ totalMerchants ?? '0' }})</button>
      <button onclick="filterMerchants('active')" id="filterActiveBtn" class="filter-btn" style="background: #10b981; color: white; padding: 8px 16px; border: none; border-radius: 10px; cursor: pointer;">✅ Actifs ({{ activeMerchantsCount ?? '0' }})</button>
      <button onclick="filterMerchants('inactive')" id="filterInactiveBtn" class="filter-btn" style="background: #ef4444; color: white; padding: 8px 16px; border: none; border-radius: 10px; cursor: pointer;">❌ Inactifs ({{ inactiveMerchantsCount ?? '0' }})</button>
      <button onclick="filterMerchants('pending')" id="filterPendingBtn" class="filter-btn" style="background: #f59e0b; color: white; padding: 8px 16px; border: none; border-radius: 10px; cursor: pointer;">⏳ En attente ({{ pendingMerchantsCount ?? '0' }})</button>
    </div>
  </header>

  <div id="merchantsGrid" class="home-grid home-grid-products" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 24px;">
    @each(merchant in allMerchants)
      @let(statusClass = merchant.verification_status === 'verified' || merchant.is_verified ? 'active' : (merchant.verification_status === 'pending' ? 'pending' : 'inactive'))
      @let(statusColor = statusClass === 'active' ? '#10b981' : (statusClass === 'pending' ? '#f59e0b' : '#ef4444'))
      @let(statusIcon = statusClass === 'active' ? '✅' : (statusClass === 'pending' ? '⏳' : '❌'))
      @let(statusText = statusClass === 'active' ? 'Actif' : (statusClass === 'pending' ? 'En attente' : 'Inactif'))
      
      <div class="tile tile-product merchant-card" data-status="{{ statusClass }}" style="background: white; border-radius: 16px; padding: 20px; border-left: 4px solid {{ statusColor }}; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); transition: all 0.2s ease;">
        <div class="tile-body">
          <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <div style="width: 56px; height: 56px; background: linear-gradient(135deg, {{ statusColor }}, {{ statusColor }}80); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 20px;">
                {{ merchant.initials ?? substr(merchant.full_name, 0, 2) ?? '🏪' }}
              </div>
              <div>
                <h3 class="tile-title" style="margin: 0; font-size: 1rem; font-weight: 700;">{{ merchant.full_name ?? merchant.company_name ?? merchant.shop_name }}</h3>
                <p style="margin: 4px 0 0; font-size: 0.7rem; color: #64748b;">{{ merchant.email }}</p>
              </div>
            </div>
            <span class="status-pill" style="background: {{ statusColor }}20; color: {{ statusColor }}; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.7rem; white-space: nowrap;">
              {{ statusIcon }} {{ statusText }}
            </span>
          </div>
          
          <div style="margin: 12px 0;">
            <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 8px;">
              <span style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">🏢 {{ merchant.commercial_name ?? merchant.shop_name ?? 'N/A' }}</span>
              <span style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">📞 {{ merchant.whatsapp_phone ?? merchant.phone ?? 'N/A' }}</span>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <span style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">📍 {{ merchant.shop_address ?? merchant.residence_address ?? 'N/A' }}</span>
              <span style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">📅 {{ merchant.created_at_formatted ?? 'N/A' }}</span>
            </div>
          </div>
          
          @if(merchant.verification_status === 'pending')
            <div style="margin: 12px 0;">
              <div style="background: #fef3c7; border-radius: 8px; padding: 8px; text-align: center;">
                <p style="margin: 0; font-size: 11px; color: #d97706;">⏳ En attente de vérification</p>
              </div>
            </div>
          @endif
          
          <div style="display: flex; gap: 8px; margin-top: 16px;">
            <button onclick="toggleMerchantStatus({{ merchant.id }}, '{{ statusClass }}')" 
                    style="flex: 1; background: {{ statusClass === 'active' ? '#ef4444' : '#10b981' }}; color: white; border: none; border-radius: 10px; padding: 8px 12px; font-size: 12px; cursor: pointer;">
              {{ statusClass === 'active' ? '❌ Désactiver' : (statusClass === 'pending' ? '✅ Approuver' : '✅ Activer') }}
            </button>
            <button onclick="viewMerchantDetails({{ merchant.id }})" 
                    style="flex: 1; background: #3b82f6; color: white; border: none; border-radius: 10px; padding: 8px 12px; font-size: 12px; cursor: pointer;">
              🔍 Voir détails
            </button>
          </div>
        </div>
      </div>
    @else
      <p class="home-empty">Aucun marchand enregistré.</p>
    @end
  </div>
</section>

