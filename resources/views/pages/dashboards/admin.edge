        <div class="tile-body">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <div style="width: 48px; height: 48px; background: linear-gradient(135deg, #3b82f6, #8b5cf6); border-radius: 999px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 18px;">
              {{ user.initials ?? '👤' }}
            </div>
            <div>
              <h3 class="tile-title" style="margin: 0; font-size: 1rem; font-weight: 700;">{{ user.name }}</h3>
              <p class="detail" style="margin: 0; font-size: 0.7rem; color: #64748b;">{{ user.role }}</p>
            </div>
          </div>
          <div class="tile-meta" style="display: flex; gap: 8px; flex-wrap: wrap;">
            <span class="meta" style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">📧 {{ user.email }}</span>
            <span class="meta" style="background: #f1f5f9; padding: 4px 10px; border-radius: 20px; font-size: 11px;">📅 {{ user.createdAt }}</span>
          </div>
        </div>
      </div>
    @else
      <p class="home-empty">Aucun utilisateur enregistré.</p>
    @end
  </div>
</section>

<!-- MODAL pour les détails de l'abonnement -->
<div id="subscriptionModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; justify-content: center; align-items: center; overflow-y: auto;">
  <div style="background: white; border-radius: 24px; max-width: 800px; width: 90%; margin: 40px auto; max-height: 90vh; overflow-y: auto; position: relative;">
    <div style="position: sticky; top: 0; background: white; padding: 20px 24px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
      <h2 style="margin: 0; font-size: 24px; font-weight: 700; color: #1e293b;">📋 Détails de l'abonnement</h2>
      <button onclick="closeSubscriptionModal()" style="background: none; border: none; font-size: 28px; cursor: pointer; color: #64748b;">&times;</button>
    </div>
    <div id="modalContent" style="padding: 24px;">
      <div style="text-align: center; padding: 40px;">
        <div class="loader" style="border: 3px solid #f3f3f3; border-top: 3px solid #8b5cf6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
        <p>Chargement des détails...</p>
      </div>
    </div>
  </div>
</div>

<!-- MODAL pour les détails du marchand -->
<div id="merchantModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1001; justify-content: center; align-items: center; overflow-y: auto;">
  <div style="background: white; border-radius: 24px; max-width: 900px; width: 90%; margin: 40px auto; max-height: 90vh; overflow-y: auto; position: relative;">
    <div style="position: sticky; top: 0; background: white; padding: 20px 24px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
      <h2 style="margin: 0; font-size: 24px; font-weight: 700; color: #1e293b;">🏪 Détails du marchand</h2>
      <button onclick="closeMerchantModal()" style="background: none; border: none; font-size: 28px; cursor: pointer; color: #64748b;">&times;</button>
    </div>
    <div id="merchantModalContent" style="padding: 24px;">
      <div style="text-align: center; padding: 40px;">
        <div class="loader" style="border: 3px solid #f3f3f3; border-top: 3px solid #3b82f6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
        <p>Chargement des détails...</p>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  
  .subscription-card, .merchant-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  
  .subscription-card:hover, .merchant-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 20px -8px rgba(0,0,0,0.15);
  }
  
  .tile-product:hover {
    transform: translateY(-4px);
    transition: all 0.2s ease;
  }

  select:hover:not([disabled]) {
    border-color: #3b82f6;
  }

  select[disabled]:hover {
    cursor: not-allowed;
  }
  
  .filter-btn {
    transition: all 0.2s ease;
  }
  
  .filter-btn:hover {
    opacity: 0.8;
    transform: translateY(-2px);
  }
  
  .filter-btn.active {
    box-shadow: 0 0 0 2px white, 0 0 0 4px currentColor;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 20px !important;
      margin: 20px !important;
    }
    .hero h1 {
      font-size: 32px !important;
    }
    .action-row {
      padding: 0 20px 30px !important;
    }
    .home-section {
      padding: 0 20px 30px !important;
    }
  }
</style>

<script>
// 🆕 Filtrage des marchands
let currentMerchantFilter = 'all';

function filterMerchants(filter) {
  currentMerchantFilter = filter;
  const cards = document.querySelectorAll('.merchant-card');
  
  // Mettre à jour l'apparence des boutons
  document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
  if (filter === 'all') document.getElementById('filterAllBtn')?.classList.add('active');
  else if (filter === 'active') document.getElementById('filterActiveBtn')?.classList.add('active');
  else if (filter === 'inactive') document.getElementById('filterInactiveBtn')?.classList.add('active');
  else if (filter === 'pending') document.getElementById('filterPendingBtn')?.classList.add('active');
  
  cards.forEach(card => {
    const status = card.dataset.status;
    if (filter === 'all') {
      card.style.display = 'block';
    } else if (filter === 'active' && status === 'active') {
      card.style.display = 'block';
    } else if (filter === 'inactive' && status === 'inactive') {
      card.style.display = 'block';
    } else if (filter === 'pending' && status === 'pending') {
      card.style.display = 'block';
    } else {
      card.style.display = 'none';
    }
  });
}

// 🆕 Changer le statut d'un marchand
async function toggleMerchantStatus(merchantId, currentStatus) {
  let newStatus = '';
  let actionText = '';
  
  if (currentStatus === 'active') {
    newStatus = 'inactive';
    actionText = 'désactiver';
  } else if (currentStatus === 'pending') {
    newStatus = 'active';
    actionText = 'approuver';
  } else {
    newStatus = 'active';
    actionText = 'activer';
  }
  
  if (!confirm(`Êtes-vous sûr de vouloir ${actionText} ce marchand ?`)) return;
  
  try {
    const response = await fetch(`/api/admin/merchants/${merchantId}/status`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ status: newStatus })
    });
    
    const result = await response.json();
    
    if (result.success) {
      alert(`✅ Marchand ${actionText} avec succès !`);
      location.reload();
    } else {
      alert('Erreur: ' + (result.message || 'Impossible de changer le statut'));
    }
  } catch (error) {
    console.error('❌ Erreur réseau:', error);
    alert('Erreur réseau. Veuillez réessayer.');
  }
}

// 🆕 Voir les détails d'un marchand
async function viewMerchantDetails(merchantId) {
  const modal = document.getElementById('merchantModal');
  const modalContent = document.getElementById('merchantModalContent');
  
  modal.style.display = 'flex';
  modalContent.innerHTML = `
    <div style="text-align: center; padding: 40px;">
      <div class="loader" style="border: 3px solid #f3f3f3; border-top: 3px solid #3b82f6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
      <p>Chargement des détails...</p>
    </div>
  `;
  
  try {
    const response = await fetch(`/api/admin/merchants/${merchantId}`);
    const result = await response.json();
    
    if (result.success && result.data) {
      displayMerchantDetails(result.data);
    } else {
      modalContent.innerHTML = `<div style="text-align: center; padding: 40px; color: #ef4444;"><p>❌ Erreur lors du chargement des détails</p><button onclick="closeMerchantModal()" style="margin-top: 16px; padding: 8px 16px; background: #3b82f6; color: white; border: none; border-radius: 8px; cursor: pointer;">Fermer</button></div>`;
    }
  } catch (error) {
    console.error('Erreur:', error);
    modalContent.innerHTML = `<div style="text-align: center; padding: 40px; color: #ef4444;"><p>❌ Erreur réseau</p><button onclick="closeMerchantModal()" style="margin-top: 16px; padding: 8px 16px; background: #3b82f6; color: white; border: none; border-radius: 8px; cursor: pointer;">Fermer</button></div>`;
  }
}

// 🆕 Afficher les détails du marchand
function displayMerchantDetails(merchant) {
  const modalContent = document.getElementById('merchantModalContent');
  
  const statusColor = merchant.status === 'active' ? '#10b981' : merchant.status === 'pending' ? '#f59e0b' : '#ef4444';
  const statusIcon = merchant.status === 'active' ? '✅' : merchant.status === 'pending' ? '⏳' : '❌';
  const statusText = merchant.status === 'active' ? 'Actif' : merchant.status === 'pending' ? 'En attente' : 'Inactif';
  
  modalContent.innerHTML = `
    <div style="margin-bottom: 24px;">
      <div style="background: linear-gradient(135deg, ${statusColor}, ${statusColor}80); border-radius: 16px; padding: 20px; color: white; margin-bottom: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
          <div>
            <p style="opacity: 0.8; margin: 0 0 4px;">Marchand</p>
            <h3 style="margin: 0; font-size: 22px;">${escapeHtml(merchant.full_name || merchant.company_name)}</h3>
            <p style="margin: 4px 0 0; opacity: 0.8;">${escapeHtml(merchant.email)}</p>
          </div>
          <span style="background: rgba(255,255,255,0.2); color: white; padding: 8px 16px; border-radius: 20px; font-size: 14px;">
            ${statusIcon} ${statusText}
          </span>
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-bottom: 20px;">
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Nom commercial</p>
          <p style="font-weight: 700; font-size: 16px; margin: 0;">${escapeHtml(merchant.commercial_name || merchant.shop_name || 'N/A')}</p>
        </div>
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Téléphone WhatsApp</p>
          <p style="font-weight: 700; font-size: 16px; margin: 0;">${escapeHtml(merchant.whatsapp_phone || merchant.phone || 'N/A')}</p>
        </div>
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">RCCM</p>
          <p style="font-weight: 700; font-size: 16px; margin: 0;">${escapeHtml(merchant.rccm_number || 'Non renseigné')}</p>
        </div>
      </div>
      
      <div style="background: #f8fafc; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
        <h4 style="margin: 0 0 12px; color: #1e293b;">📍 Adresse</h4>
        <p style="margin: 0;">${escapeHtml(merchant.shop_address || merchant.business_address || merchant.residence_address || 'Non renseignée')}</p>
      </div>
      
      <div style="background: #f8fafc; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
        <h4 style="margin: 0 0 12px; color: #1e293b;">📦 Produits</h4>
        <p style="margin: 0;">${merchant.products_count ?? '0'} produits en vente</p>
      </div>
      
      <div style="background: #f8fafc; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
        <h4 style="margin: 0 0 12px; color: #1e293b;">📅 Dates</h4>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Inscription</p>
            <p style="font-weight: 600; margin: 0;">${merchant.created_at_formatted || 'N/A'}</p>
          </div>
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Dernière activité</p>
            <p style="font-weight: 600; margin: 0;">${merchant.last_activity || 'N/A'}</p>
          </div>
        </div>
      </div>
      
      <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px;">
        <button onclick="closeMerchantModal()" style="padding: 10px 20px; background: #e2e8f0; border: none; border-radius: 10px; cursor: pointer;">Fermer</button>
        <button onclick="toggleMerchantStatus(${merchant.id}, '${merchant.status}'); closeMerchantModal();" 
                style="padding: 10px 20px; background: ${merchant.status === 'active' ? '#ef4444' : '#10b981'}; color: white; border: none; border-radius: 10px; cursor: pointer;">
          ${merchant.status === 'active' ? '❌ Désactiver' : (merchant.status === 'pending' ? '✅ Approuver' : '✅ Activer')}
        </button>
      </div>
    </div>
  `;
}

function closeMerchantModal() {
  document.getElementById('merchantModal').style.display = 'none';
}

// Fonction pour mettre à jour le statut d'une commande
async function updateOrderStatus(orderId, newStatus) {
  const statusLabels = {
    'pending': 'En attente',
    'processing': 'En cours',
    'shipped': 'Expédiée',
    'delivered': 'Livrée',
    'cancelled': 'Annulée'
  };

  const statusLabel = statusLabels[newStatus] || newStatus;

  if (!orderId || orderId === 'undefined' || orderId === 'null') {
    console.error('❌ ID de commande invalide:', orderId);
    alert('Erreur: ID de commande invalide');
    return;
  }

  if (!confirm(`Êtes-vous sûr de vouloir passer cette commande en "${statusLabel}" ?`)) return;

  try {
    const response = await fetch(`/api/orders/${orderId}/status`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ status: newStatus })
    });

    const result = await response.json();

    if (result.success) {
      alert(`✅ Statut changé : ${statusLabel}`);
      location.reload();
    } else {
      alert('Erreur: ' + (result.message || 'Impossible de changer le statut'));
    }
  } catch (error) {
    console.error('❌ Erreur réseau:', error);
    alert('Erreur réseau. Veuillez réessayer.');
  }
}

// Fonction pour ouvrir la modal avec les détails de l'abonnement
async function openSubscriptionModal(subscriptionId) {
  const modal = document.getElementById('subscriptionModal');
  const modalContent = document.getElementById('modalContent');
  
  modal.style.display = 'flex';
  modalContent.innerHTML = `
    <div style="text-align: center; padding: 40px;">
      <div class="loader" style="border: 3px solid #f3f3f3; border-top: 3px solid #8b5cf6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
      <p>Chargement des détails...</p>
    </div>
  `;
  
  try {
    const response = await fetch(`/dashboards/api/subscriptions/${subscriptionId}`);
    const result = await response.json();
    
    if (result.success && result.data) {
      displaySubscriptionDetails(result.data);
    } else {
      modalContent.innerHTML = `<div style="text-align: center; padding: 40px; color: #ef4444;"><p>❌ Erreur lors du chargement des détails</p><button onclick="closeSubscriptionModal()" style="margin-top: 16px; padding: 8px 16px; background: #8b5cf6; color: white; border: none; border-radius: 8px; cursor: pointer;">Fermer</button></div>`;
    }
  } catch (error) {
    console.error('Erreur:', error);
    modalContent.innerHTML = `<div style="text-align: center; padding: 40px; color: #ef4444;"><p>❌ Erreur réseau</p><button onclick="closeSubscriptionModal()" style="margin-top: 16px; padding: 8px 16px; background: #8b5cf6; color: white; border: none; border-radius: 8px; cursor: pointer;">Fermer</button></div>`;
  }
}

function displaySubscriptionDetails(sub) {
  const modalContent = document.getElementById('modalContent');
  
  const statusColor = sub.status === 'active' ? '#10b981' : sub.status === 'pending' ? '#f59e0b' : sub.status === 'cancelled' ? '#ef4444' : '#6b7280';
  const statusIcon = sub.status === 'active' ? '✅' : sub.status === 'pending' ? '⏳' : sub.status === 'cancelled' ? '❌' : '📋';
  const statusLabel = sub.status === 'active' ? 'Actif' : sub.status === 'pending' ? 'En attente' : sub.status === 'cancelled' ? 'Annulé' : sub.status === 'expired' ? 'Expiré' : sub.status;
  
  modalContent.innerHTML = `
    <div style="margin-bottom: 24px;">
      <div style="background: linear-gradient(135deg, #8b5cf6, #ec4899); border-radius: 16px; padding: 20px; color: white; margin-bottom: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
          <div>
            <p style="opacity: 0.8; margin: 0 0 4px;">Marchand</p>
            <h3 style="margin: 0; font-size: 20px;">${escapeHtml(sub.merchantName)}</h3>
            <p style="margin: 4px 0 0; opacity: 0.8;">${escapeHtml(sub.merchantEmail)}</p>
          </div>
          <span style="background: ${statusColor}20; color: ${statusColor}; padding: 6px 12px; border-radius: 20px; font-size: 14px;">
            ${statusIcon} ${statusLabel}
          </span>
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin-bottom: 20px;">
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Plan</p>
          <p style="font-weight: 700; font-size: 18px; margin: 0;">${escapeHtml(sub.planName)}</p>
        </div>
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Montant</p>
          <p style="font-weight: 700; font-size: 18px; color: #8b5cf6; margin: 0;">${sub.price}</p>
        </div>
        <div style="background: #f8fafc; border-radius: 12px; padding: 16px;">
          <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Durée</p>
          <p style="font-weight: 700; font-size: 18px; margin: 0;">${sub.duration} jours</p>
        </div>
      </div>
      
      <div style="background: #f8fafc; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Type d'abonnement</p>
            <p style="font-weight: 600; margin: 0;">${sub.subscriptionType === 'all_products' ? '🌍 Global (tous les produits)' : '📦 Produit unique'}</p>
          </div>
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Produits boostés</p>
            <p style="font-weight: 600; margin: 0;">${sub.boostedProductsCount} / ${sub.maxProducts === 999999 ? '∞' : sub.maxProducts}</p>
          </div>
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Renouvellement auto</p>
            <p style="font-weight: 600; margin: 0;">${sub.autoRenew ? '✅ Activé' : '❌ Désactivé'}</p>
          </div>
        </div>
      </div>
      
      <div style="background: #f8fafc; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px;">
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Date de début</p>
            <p style="font-weight: 600; margin: 0;">${sub.startDate || 'Non démarré'}</p>
          </div>
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Date de fin</p>
            <p style="font-weight: 600; margin: 0;">${sub.endDate || 'N/A'}</p>
          </div>
          <div>
            <p style="color: #64748b; margin: 0 0 4px; font-size: 12px;">Jours restants</p>
            <p style="font-weight: 600; color: ${sub.daysRemaining > 0 ? '#10b981' : '#ef4444'}; margin: 0;">${sub.daysRemaining > 0 ? sub.daysRemaining + ' jours' : (sub.daysRemaining === 0 ? 'Expire aujourd\'hui' : 'Expiré')}</p>
          </div>
        </div>
        ${sub.daysRemaining > 0 ? `
          <div style="margin-top: 12px;">
            <div style="background: #e2e8f0; border-radius: 10px; overflow: hidden; height: 6px;">
              <div style="width: ${((sub.duration - sub.daysRemaining) / sub.duration * 100)}%; height: 6px; background: linear-gradient(90deg, #8b5cf6, #ec4899);"></div>
            </div>
          </div>
        ` : ''}
      </div>
      
      <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <button onclick="closeSubscriptionModal()" style="padding: 10px 20px; background: #e2e8f0; border: none; border-radius: 10px; cursor: pointer;">Fermer</button>
      </div>
    </div>
  `;
}

function closeSubscriptionModal() {
  document.getElementById('subscriptionModal').style.display = 'none';
}

// Fermer la modal en cliquant en dehors
document.getElementById('subscriptionModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeSubscriptionModal();
  }
});

document.getElementById('merchantModal').addEventListener('click', function(e) {
  if (e.target === this) {
    closeMerchantModal();
  }
});

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// Attacher les événements aux selects après le chargement de la page
document.addEventListener('DOMContentLoaded', function() {
  const selects = document.querySelectorAll('.status-select');

  selects.forEach((select) => {
    if (select.disabled) {
      return;
    }

    select.removeEventListener('change', select._listener);
    const listener = function() {
      const orderIdValue = this.getAttribute('data-order-id');
      const newStatus = this.value;
      updateOrderStatus(orderIdValue, newStatus);
    };
    select.addEventListener('change', listener);
    select._listener = listener;
  });
  
  // Activer le filtre "Tous" par défaut
  filterMerchants('all');
});
</script>
@end
