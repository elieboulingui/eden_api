                  <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; font-size: 14px;">{{ usage.user_initials }}</div>
                  <div>
                    <div style="font-weight: 600; color: #111827;">{{ usage.user_name }}</div>
