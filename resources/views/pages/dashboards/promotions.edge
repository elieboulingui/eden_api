          </tr>
        </thead>
        <tbody>
          @each(coupon in couponRows)
            <tr style="border-bottom: 1px solid #f0f0f0;">
              <td style="padding: 16px 20px; font-weight: 600; color: #111827;">{{ coupon.code }}</td>
              <td style="padding: 16px 20px; color: #6b7280;">{{ coupon.type }}</td>
              <td style="padding: 16px 20px; font-weight: 500; color: #10b981;">{{ coupon.discount }}</td>
              <td style="padding: 16px 20px; color: #6b7280;">{{ coupon.usage_count ?? 0 }}/{{ coupon.max_uses ?? '∞' }}</td>
              <td style="padding: 16px 20px;">
                @if(coupon.status === 'actif')
                  <span style="background: #d1fae5; color: #065f46; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;">● Actif</span>
                @elseif(coupon.status === 'expiré')
                  <span style="background: #fee2e2; color: #991b1b; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;">● Expiré</span>
                @else
                  <span style="background: #fed7aa; color: #92400e; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 500;">● Épuisé</span>
                @end
              </td>
            </tr>
          @else
            <tr>
              <td colspan="5" style="padding: 40px; text-align: center; color: #9ca3af;">Aucun coupon actif.</td>
            </tr>
          @end
        </tbody>
      </table>
    </div>
