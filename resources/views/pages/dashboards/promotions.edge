@layout()
<section class="hero" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 24px; margin: 20px 30px; padding: 60px 50px;">
  <p class="text-sm uppercase tracking-[0.3em]" style="color: rgba(255,255,255,0.8);">AdminMarket Promotions</p>
  <h1 style="color: white; font-size: 48px; margin: 16px 0;">Gestion des campagnes & codes promo</h1>
  <p style="color: rgba(255,255,255,0.9); font-size: 18px;">Suivez l'utilisation des promotions, ajoutez-en et ajustez-les au fil des campagnes.</p>
</section>

<div style="max-width: 1400px; margin: 0 auto; padding: 0 30px 60px;">
  <!-- Statistiques -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; margin-bottom: 48px;">
    @each(stat in promoStats)
      <div style="background: white; border-radius: 20px; padding: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06); transition: transform 0.2s, box-shadow 0.2s;">
        <div style="font-size: 32px; margin-bottom: 12px;">{{ stat.icon ?? '🎯' }}</div>
        <p style="color: #6b7280; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;">{{ stat.title }}</p>
        <p style="color: #111827; font-size: 32px; font-weight: 700; margin-bottom: 8px;">{{ stat.value }}</p>
        <p style="color: #9ca3af; font-size: 13px;">{{ stat.detail }}</p>
      </div>
    @end
  </div>

  <!-- Codes actifs -->
  <div style="background: white; border-radius: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-bottom: 48px; overflow: hidden;">
    <div style="padding: 20px 24px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center;">
      <h3 style="font-size: 18px; font-weight: 600; color: #111827;">📋 Codes actifs</h3>
      <span style="color: #9ca3af; font-size: 13px;">Usage & type</span>
